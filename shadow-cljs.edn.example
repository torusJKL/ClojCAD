{:source-paths ["src"]
 :dependencies []
 :nrepl {:port #shadow/env ["NREPL_PORT" 8777]}
 :builds
 {:dev
   {:target :browser
    :output-dir "public/js"
    :modules {:main {:init-fn ClojCAD.core/init}}

   :devtools {:http-port 8700
              :http-root "public"
              :nrepl-port 8777}}}}
